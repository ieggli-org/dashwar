# Database (local Docker or Supabase URI for production)
# Supabase: Settings → Database → Connection string (URI, use Transaction pooler port 6543)
DATABASE_URL=postgresql://dashwar:dashwar@localhost:5432/dashwar

# Optional: cache/session
REDIS_URL=redis://localhost:6379

# AI analysis (Impact page; optional — uses fallback text if unset)
OPENAI_API_KEY=

# External APIs (keys TBD per source)
NEWS_API_KEY=
REUTERS_API_KEY=
AP_API_KEY=

# Client-side (browser)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_MAP_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Server-side API base (for server-to-server)
API_BASE_URL=http://localhost:3000

# Ingest: polling interval in minutes
INGEST_POLL_MINUTES=30

# Client poll interval for timeline (ms; default 120000 = 2 min)
NEXT_PUBLIC_POLL_INTERVAL_MS=120000

# Optional: topojson/geo URL for map (default: world-atlas 110m)
# NEXT_PUBLIC_GEO_URL=https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json

# Feature flags (optional)
NEXT_PUBLIC_FEATURE_ALERTS=false
