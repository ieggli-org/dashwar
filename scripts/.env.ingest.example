# Copy to .env.ingest and set values. scripts/.env.ingest is gitignored; do not commit real credentials.
#
# For periodic ingest (scripts/ingest-periodic.sh):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# For triggering production ingest (scripts/trigger-vercel-ingest.sh): use the same secret as in Vercel.
# CRON_SECRET=<same value as in Vercel → Settings → Environment Variables>

DATABASE_URL=
CRON_SECRET=
